}
</script>

<script>
// ============ 数据模型 ============
let state = {
  domains: [],
  rules: [],
  defaultUrl: '',
  lastResults: []
};

const STORAGE_KEY = 'baidu_landing_url_matcher_v1';

// ============ 持久化 ============
function saveState() {
  // 1. 写 localStorage（浏览器内即时生效）
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  } catch(e) {
    toast('保存失败：' + e.message, 'danger');
  }
  // 2. 更新内嵌数据区（内存中，保存到文件时会用）
  updateEmbeddedData();
  // 3. 更新顶部保存按钮提示
  updateSaveButtonHint();
}

function updateEmbeddedData() {
  const el = document.getElementById('embedded-data');
  if (el) {
    el.textContent = '\n' + JSON.stringify(state, null, 2) + '\n';
  }
}

function loadState() {
  // 优先级：内嵌数据 > localStorage > 示例数据
  // 1. 先读内嵌数据（HTML 文件自带，跨电脑可用）
  try {
    const el = document.getElementById('embedded-data');
    if (el) {
      const raw = el.textContent.trim();
      if (raw && raw !== '/*EMBEDDED_DATA_PLACEHOLDER*/') {
        const parsed = JSON.parse(raw);
        if (parsed && (parsed.domains || parsed.rules)) {
          state = Object.assign(state, parsed);
          // 同步写一份到 localStorage，方便浏览器内即时使用
          try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
          return;
        }
      }
    }
  } catch(e) {
    console.error('读取内嵌数据失败', e);
  }

  // 2. 再读 localStorage（浏览器本地缓存）
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const parsed = JSON.parse(raw);
      state = Object.assign(state, parsed);
    }
  } catch(e) {
    console.error('加载失败', e);
  }

  // 3. 都没有，加载示例
  if (state.domains.length === 0 && state.rules.length === 0) {
    loadSampleData();
    saveState();
  }
}

// ============ 保存到 HTML 文件 ============
let fileHandle = null; // File System Access API 句柄

async function saveToHtmlFile() {
  // 先更新一次内嵌数据
  updateEmbeddedData();

  // 方案1：File System Access API（Chrome/Edge 86+，可写回原文件）
  if ('showSaveFilePicker' in window) {
    try {
      if (!fileHandle) {
        // 首次保存，让用户选文件位置
        fileHandle = await window.showSaveFilePicker({
          suggestedName: '百度竞价落地页URL匹配工具.html',
          types: [{
            description: 'HTML 文件',
            accept: {'text/html': ['.html', '.htm']}
          }]
        });
      }
      const writable = await fileHandle.createWritable();
      // 完整 HTML 文档
      const fullHtml = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
      await writable.write(fullHtml);
      await writable.close();
      toast('已保存到文件：' + fileHandle.name, 'success');
      // 清除"未保存"标记
      unsavedChanges = false;
      updateSaveButtonHint();
      return;
    } catch(e) {
      if (e.name === 'AbortError') {
        // 用户取消，静默
        return;
      }
      // File System Access 失败，降级到下载
      console.warn('File System Access API 失败，降级到下载', e);
    }
  }

  // 方案2：降级下载（所有浏览器通用）
  const fullHtml = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  const blob = new Blob([fullHtml], { type: 'text/html;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = '百度竞价落地页URL匹配工具_' + new Date().toISOString().slice(0,10) + '.html';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(a.href), 1000);
  toast('已下载新版HTML，请用新文件替换旧文件', 'success');
  unsavedChanges = false;
  updateSaveButtonHint();
}

// 监听数据变化，标记未保存
let unsavedChanges = false;
const originalSaveState = saveState;
saveState = function() {
  originalSaveState();
  unsavedChanges = true;
  updateSaveButtonHint();
};

function updateSaveButtonHint() {
  const btn = document.getElementById('btnSaveHtml');
  if (!btn) return;
  if (unsavedChanges) {
    btn.textContent = '💾 保存到文件 *';
    btn.style.background = 'var(--warning-dim)';
    btn.style.borderColor = 'var(--warning)';
    btn.style.color = 'var(--warning)';
  } else {
    btn.textContent = '💾 保存到文件';
    btn.style.background = '';
    btn.style.borderColor = '';
    btn.style.color = '';
  }
}

// 离开页面前提示
window.addEventListener('beforeunload', function(e) {
  if (unsavedChanges) {
    e.preventDefault();
    e.returnValue = '有未保存的修改，确定离开吗？';
  }
});

// ============ 示例数据 ============
function loadSampleData() {
  state.domains = [
    { id: genId(), url: 'https://sh.xuannaer.com.cn', remark: '上海站', isDefault: true, enabled: true },
    { id: genId(), url: 'https://bj.xuannaer.com.cn', remark: '北京站', isDefault: false, enabled: true },
    { id: genId(), url: 'https://js.xuannaer.com.cn', remark: '江苏站', isDefault: false, enabled: true }
  ];
  state.rules = [
    { id: genId(), type: 'plan_unit_exact', value: '上海-大词|||园区', region: '上海', domainId: state.domains[0].id, path: '/yuanqu/list/', query: 'utm_source=SEM-baidu-PC&utm_medium=PC', remark: '上海大词-园区→上海站园区列表', enabled: true },
    { id: genId(), type: 'plan_unit_exact', value: '北京-大词|||园区', region: '北京', domainId: state.domains[1].id, path: '/yuanqu/list/', query: 'utm_source=SEM-baidu-PC&utm_medium=PC', remark: '北京大词-园区→北京站园区列表', enabled: true },
    { id: genId(), type: 'unit_exact', value: '园区-奉贤URL', region: '上海', domainId: state.domains[0].id, path: '/fengxian/yuanqu/list/', query: 'utm_source=SEM-baidu-PC&utm_medium=PC', remark: '奉贤园区专区页', enabled: true },
    { id: genId(), type: 'unit_contains', value: '厂房', region: '上海', domainId: state.domains[0].id, path: '/changfang/', query: 'utm_source=SEM-baidu-PC&utm_medium=PC', remark: '厂房列表页', enabled: true },
    { id: genId(), type: 'unit_contains', value: '写字楼', region: '北京', domainId: state.domains[1].id, path: '/xiezilou/', query: 'utm_source=SEM-baidu-PC&utm_medium=PC', remark: '写字楼列表页', enabled: true }
  ];
  state.defaultUrl = 'https://sh.xuannaer.com.cn/yuanqu/list/?utm_source=SEM-baidu-PC&utm_medium=PC';
  saveState();
}

function loadSampleInput() {
  const fmt = document.querySelector('input[name="inputFormat"]:checked').value;
  const samples = {
    keyword: '奉贤区产业园厂房租赁\n卢湾工业园厂房\n上海写字楼出租\n北京朝阳区产业园\n天津武清仓库出租',
    pu: '上海-大词\t园区\t奉贤区产业园厂房租赁\n上海-大词\t厂房\t卢湾工业园厂房\n写字楼-上海\t行政区划-黄浦-huangpu\t上海黄浦区写字楼出租\n写字楼-北京\t区域-朝阳\t北京朝阳区写字楼\n仓库-天津-纯\t武清区\t天津武清仓库出租',
    full: '上海-大词\t园区\t奉贤区产业园厂房租赁\t园区\n上海-大词\t厂房\t卢湾工业园厂房\t厂房\n写字楼-上海\t行政区划-黄浦-huangpu\t上海黄浦区写字楼出租\t写字楼\n仓库-天津-纯\t武清区\t天津武清仓库出租\t仓库'
  };
  document.getElementById('inputArea').value = samples[fmt] || samples.keyword;
}

// ============ 工具函数 ============
function genId() { return 'id_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6); }

function toast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show';
  if (type === 'danger') el.style.borderColor = 'var(--danger)';
  else if (type === 'success') el.style.borderColor = 'var(--success)';
  else el.style.borderColor = 'var(--border)';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => { el.className = ''; }, 2500);
}

function encodeURIComponentSafe(s) {
  try { return encodeURIComponent(s); } catch(e) { return s; }
}

function escapeHtml(s) {
  if (s == null) return '';
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ============ 变量替换 ============
function replaceVars(str, plan, unit, kw, category) {
  if (!str) return '';
  return str
    .replace(/\{\{kw_raw\}\}/g, kw || '')
    .replace(/\{\{kw\}\}/g, encodeURIComponentSafe(kw || ''))
    .replace(/\{\{plan_raw\}\}/g, plan || '')
    .replace(/\{\{plan\}\}/g, encodeURIComponentSafe(plan || ''))
    .replace(/\{\{unit_raw\}\}/g, unit || '')
    .replace(/\{\{unit\}\}/g, encodeURIComponentSafe(unit || ''))
    .replace(/\{\{category_raw\}\}/g, category || '')
    .replace(/\{\{category\}\}/g, encodeURIComponentSafe(category || ''));
}

// ============ 匹配核心 ============
function buildUrl(rule, plan, unit, kw, category) {
  const domain = state.domains.find(d => d.id === rule.domainId);
  const base = (domain && domain.enabled) ? domain.url.replace(/\/+$/, '') : '';
  let path = replaceVars(rule.path || '', plan, unit, kw, category);
  if (path && !path.startsWith('/')) path = '/' + path;
  let query = replaceVars(rule.query || '', plan, unit, kw, category).replace(/^&+/, '').replace(/&+$/, '');
  let url = base + path;
  if (query) {
    url += (url.includes('?') ? '&' : '?') + query;
  }
  return url;
}

function matchOne(plan, unit, kw, category) {
  const sortedRules = state.rules.slice().sort((a, b) => {
    // 保持原始顺序，state.rules本身就是优先级顺序
    return state.rules.indexOf(a) - state.rules.indexOf(b);
  });

  for (let i = 0; i < state.rules.length; i++) {
    const rule = state.rules[i];
    if (!rule.enabled) continue;
    let matched = false;
    const v = rule.value || '';
    try {
      switch (rule.type) {
        case 'keyword_exact': matched = (kw === v); break;
        case 'keyword_contains': matched = v && kw.includes(v); break;
        case 'keyword_regex': matched = v && new RegExp(v).test(kw); break;
        case 'unit_exact': matched = v && unit === v; break;
        case 'unit_contains': matched = v && unit && unit.includes(v); break;
        case 'plan_exact': matched = v && plan === v; break;
        case 'plan_contains': matched = v && plan && plan.includes(v); break;
        case 'plan_unit_exact': {
          // value 格式：计划|||单元
          const sep = v.indexOf('|||');
          if (sep >= 0) {
            const pv = v.substring(0, sep);
            const uv = v.substring(sep + 3);
            matched = (plan === pv && unit === uv);
          }
          break;
        }
        case 'category_exact': matched = v && category === v; break;
        case 'category_contains': matched = v && category && category.includes(v); break;
      }
    } catch(e) {
      // 正则错误等
      matched = false;
    }
    if (matched) {
      return {
        matched: true,
        viaDefault: false,
        rule: rule,
        url: buildUrl(rule, plan, unit, kw, category),
        matchType: getTypeName(rule.type)
      };
    }
  }
  // 默认URL
  if (state.defaultUrl && state.defaultUrl.trim()) {
    return {
      matched: true,
      viaDefault: true,
      rule: null,
      url: replaceVars(state.defaultUrl.trim(), plan, unit, kw, category),
      matchType: '默认URL'
    };
  }
  return { matched: false, viaDefault: false, rule: null, url: '', matchType: '' };
}

function getTypeName(t) {
  const map = {
    keyword_exact: '关键词精确', keyword_contains: '关键词包含', keyword_regex: '关键词正则',
    unit_exact: '单元精确', unit_contains: '单元包含',
    plan_exact: '计划精确', plan_contains: '计划包含',
    plan_unit_exact: '计划+单元',
    category_exact: '类别精确', category_contains: '类别包含'
  };
  return map[t] || t;
}

function getTypeColor(t) {
  if (t.startsWith('keyword')) return 'primary';
  if (t.startsWith('unit')) return 'accent';
  if (t.startsWith('plan')) return 'warning';
  if (t.startsWith('category')) return 'success';
  return 'muted';
}

// ============ 执行匹配 ============
function parseInput(text, format) {
  const lines = text.split(/\r?\n/).map(l => l.replace(/\r/g, '')).filter(l => l.trim());
  return lines.map(line => {
    const parts = line.split('\t');
    if (format === 'keyword') {
      return { plan: '', unit: '', kw: parts[0] ? parts[0].trim() : '', category: '' };
    } else if (format === 'pu') {
      return { plan: (parts[0]||'').trim(), unit: (parts[1]||'').trim(), kw: (parts[2]||'').trim(), category: '' };
    } else if (format === 'full') {
      return { plan: (parts[0]||'').trim(), unit: (parts[1]||'').trim(), kw: (parts[2]||'').trim(), category: (parts[3]||'').trim() };
    }
    return { plan: '', unit: '', kw: '', category: '' };
  }).filter(r => r.kw || r.plan || r.unit);
}

function runMatch() {
  const text = document.getElementById('inputArea').value;
  if (!text.trim()) { toast('请先粘贴关键词', 'danger'); return; }
  const format = document.querySelector('input[name="inputFormat"]:checked').value;
  const rows = parseInput(text, format);
  if (rows.length === 0) { toast('未解析到有效数据', 'danger'); return; }

  const results = rows.map(r => {
    const m = matchOne(r.plan, r.unit, r.kw, r.category);
    return Object.assign({}, r, m);
  });
  state.lastResults = results;
  renderResults(results);
  toast('匹配完成，共 ' + results.length + ' 条', 'success');
}

function renderResults(results) {
  const card = document.getElementById('resultCard');
  const body = document.getElementById('resultBody');
  card.classList.remove('hidden');

  let matched = 0, unmatched = 0, viaDefault = 0;
  results.forEach(r => {
    if (!r.matched) unmatched++;
    else if (r.viaDefault) viaDefault++;
    else matched++;
  });
  document.getElementById('stat-total').textContent = results.length;
  document.getElementById('stat-matched').textContent = matched;
  document.getElementById('stat-unmatched').textContent = unmatched;
  document.getElementById('stat-default').textContent = viaDefault;

  body.innerHTML = results.map((r, i) => {
    let statusTag;
    if (!r.matched) statusTag = '<span class="tag tag-danger">未匹配</span>';
    else if (r.viaDefault) statusTag = '<span class="tag tag-warning">默认URL</span>';
    else statusTag = '<span class="tag tag-success">已匹配</span>';

    const ruleTag = r.rule
      ? '<span class="tag tag-muted">' + escapeHtml(r.rule.remark || r.rule.value || '') + '</span>'
      : (r.viaDefault ? '<span class="tag tag-muted">兜底</span>' : '<span class="tag tag-muted">—</span>');

    const typeTag = r.matchType
      ? '<span class="tag tag-' + (r.viaDefault ? 'warning' : getTypeColor(r.rule ? r.rule.type : '')) + '">' + escapeHtml(r.matchType) + '</span>'
      : '—';

    return '<tr>' +
      '<td>' + (i + 1) + '</td>' +
      '<td>' + escapeHtml(r.plan) + '</td>' +
      '<td>' + escapeHtml(r.unit) + '</td>' +
      '<td>' + escapeHtml(r.kw) + '</td>' +
      '<td>' + escapeHtml(r.category) + '</td>' +
      '<td>' + ruleTag + '</td>' +
      '<td>' + typeTag + '</td>' +
      '<td class="url-cell" onclick="copyText(this.textContent)" title="点击复制">' + escapeHtml(r.url || '—') + '</td>' +
      '<td>' + statusTag + '</td>' +
      '</tr>';
  }).join('');
}

function clearResults() {
  document.getElementById('resultCard').classList.add('hidden');
  state.lastResults = [];
}

function copyAllResults() {
  if (!state.lastResults.length) { toast('没有结果可复制', 'danger'); return; }
  const header = '计划\t单元\t关键词\t类别\t命中规则\t匹配类型\t最终URL\t状态';
  const lines = state.lastResults.map(r => {
    const ruleDesc = r.rule ? (r.rule.remark || r.rule.value || '') : (r.viaDefault ? '默认URL' : '');
    const status = !r.matched ? '未匹配' : (r.viaDefault ? '默认URL' : '已匹配');
    return [r.plan, r.unit, r.kw, r.category, ruleDesc, r.matchType, r.url, status].join('\t');
  });
  copyText(header + '\n' + lines.join('\n'));
  toast('已复制 ' + state.lastResults.length + ' 条结果到剪贴板', 'success');
}

function copyUnmatched() {
  const unmatched = state.lastResults.filter(r => !r.matched);
  if (!unmatched.length) { toast('没有未匹配项', 'danger'); return; }
  const text = unmatched.map(r => [r.plan, r.unit, r.kw, r.category].filter(Boolean).join('\t')).join('\n');
  copyText(text);
  toast('已复制 ' + unmatched.length + ' 条未匹配项', 'success');
}

function exportResults() {
  if (!state.lastResults.length) { toast('没有结果可导出', 'danger'); return; }
  const header = '计划,单元,关键词,类别,命中规则,匹配类型,最终URL,状态';
  const lines = state.lastResults.map(r => {
    const ruleDesc = r.rule ? (r.rule.remark || r.rule.value || '') : (r.viaDefault ? '默认URL' : '');
    const status = !r.matched ? '未匹配' : (r.viaDefault ? '默认URL' : '已匹配');
    return [r.plan, r.unit, r.kw, r.category, ruleDesc, r.matchType, r.url, status]
      .map(v => '"' + String(v).replace(/"/g, '""') + '"').join(',');
  });
  const csv = '\ufeff' + header + '\n' + lines.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = '落地页URL匹配结果_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  toast('CSV 已导出', 'success');
}

function copyText(text) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => toast('已复制', 'success'));
  } else {
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta); ta.select();
    try { document.execCommand('copy'); toast('已复制', 'success'); } catch(e) { toast('复制失败', 'danger'); }
    document.body.removeChild(ta);
  }
}

// ============ Tab 切换 ============
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.toggle('active', c.id === 'tab-' + name));
  if (name === 'rules') renderRules();
  if (name === 'domains') renderDomains();
}

// ============ 规则渲染 ============
let selectedRuleIds = new Set();

function renderRules() {
  const body = document.getElementById('rulesBody');
  document.getElementById('rules-count').textContent = state.rules.length;

  // 刷新地域筛选下拉
  refreshRegionFilter();

  // 地域筛选
  const regionFilter = (document.getElementById('ruleRegionFilter') || {}).value || '';
  // 搜索过滤
  const search = (document.getElementById('ruleSearch') || {}).value || '';
  const searchLower = search.trim().toLowerCase();
  let filtered = state.rules;
  if (regionFilter) {
    filtered = filtered.filter(r => (r.region || '') === regionFilter);
  }
  if (searchLower) {
    filtered = filtered.filter(r => {
      return (r.value || '').toLowerCase().includes(searchLower) ||
             (r.remark || '').toLowerCase().includes(searchLower) ||
             (r.path || '').toLowerCase().includes(searchLower) ||
             (r.query || '').toLowerCase().includes(searchLower) ||
             (r.region || '').toLowerCase().includes(searchLower) ||
             getTypeName(r.type).includes(searchLower);
    });
  }

  if (filtered.length === 0) {
    body.innerHTML = '<tr><td colspan="10"><div class="empty-state"><div class="icon">📋</div>' + ((searchLower || regionFilter) ? '没有匹配筛选条件的规则' : '暂无规则，点击右上角「添加规则」或用「批量粘贴建规则」开始配置') + '</div></td></tr>';
    updateBatchBar();
    return;
  }

  body.innerHTML = filtered.map((r) => {
    const i = state.rules.indexOf(r);
    const opts = ['keyword_exact','keyword_contains','keyword_regex','unit_exact','unit_contains','plan_exact','plan_contains','plan_unit_exact','category_exact','category_contains']
      .map(t => '<option value="' + t + '"' + (r.type === t ? ' selected' : '') + '>' + getTypeName(t) + '</option>').join('');

    const domainSel = state.domains.length
      ? '<select data-field="domainId" data-id="' + r.id + '">' +
        state.domains.map(d => '<option value="' + d.id + '"' + (r.domainId === d.id ? ' selected' : '') + '>' + escapeHtml(d.url) + '</option>').join('') +
        '</select>'
      : '<span style="color:var(--danger);font-size:12px;">请先添加域名</span>';

    const checked = selectedRuleIds.has(r.id) ? ' checked' : '';
    const remarkHint = r.remark ? ' title="' + escapeHtml(r.remark) + '"' : '';

    return '<tr data-id="' + r.id + '" draggable="true"' + remarkHint + '>' +
      '<td><input type="checkbox" class="rule-checkbox" data-id="' + r.id + '"' + checked + ' onchange="toggleSelectRule(\'' + r.id + '\', this.checked)"></td>' +
      '<td><span class="drag-handle" title="拖拽排序">⠿</span> ' + (i + 1) + '</td>' +
      '<td><select data-field="type" data-id="' + r.id + '">' + opts + '</select></td>' +
      '<td><input type="text" data-field="value" data-id="' + r.id + '" value="' + escapeHtml(r.value) + '" placeholder="匹配值"></td>' +
      '<td><input type="text" data-field="region" data-id="' + r.id + '" value="' + escapeHtml(r.region || '') + '" placeholder="上海" style="font-size:12px;"></td>' +
      '<td>' + domainSel + '</td>' +
      '<td><input type="text" data-field="path" data-id="' + r.id + '" value="' + escapeHtml(r.path) + '" placeholder="/yuanqu/list/"></td>' +
      '<td><input type="text" data-field="query" data-id="' + r.id + '" value="' + escapeHtml(r.query) + '" placeholder="utm_source=SEM-baidu-PC&utm_medium=PC"></td>' +
      '<td><label class="switch"><input type="checkbox" data-field="enabled" data-id="' + r.id + '"' + (r.enabled ? ' checked' : '') + '><span class="slider"></span></label></td>' +
      '<td>' +
        '<button class="btn btn-sm btn-icon" onclick="duplicateRule(\'' + r.id + '\')" title="复制此规则">⎘</button> ' +
        '<button class="btn btn-sm btn-icon" onclick="editRemark(\'' + r.id + '\')" title="备注">✎</button> ' +
        '<button class="btn btn-sm btn-icon btn-danger" onclick="deleteRule(\'' + r.id + '\')" title="删除">✕</button>' +
      '</td>' +
      '</tr>';
  }).join('');

  // 绑定输入事件
  body.querySelectorAll('input[data-field],select[data-field]').forEach(el => {
    const ev = el.type === 'checkbox' ? 'change' : 'input';
    el.addEventListener(ev, function() {
      const id = this.dataset.id;
      const field = this.dataset.field;
      const rule = state.rules.find(x => x.id === id);
      if (!rule) return;
      rule[field] = (this.type === 'checkbox') ? this.checked : this.value;
      saveState();
    });
  });

  // 拖拽排序
  enableDragSort(body, 'rules');
  updateBatchBar();
}

// === 批量选择 ===
function toggleSelectRule(id, checked) {
  if (checked) selectedRuleIds.add(id);
  else selectedRuleIds.delete(id);
  updateBatchBar();
}

function toggleSelectAll(checked) {
  if (checked) {
    state.rules.forEach(r => selectedRuleIds.add(r.id));
  } else {
    selectedRuleIds.clear();
  }
  renderRules();
}

function clearSelection() {
  selectedRuleIds.clear();
  const selectAll = document.getElementById('ruleSelectAll');
  if (selectAll) selectAll.checked = false;
  renderRules();
}

function updateBatchBar() {
  const bar = document.getElementById('batchBar');
  const countEl = document.getElementById('batchSelectedCount');
  if (!bar) return;
  if (selectedRuleIds.size > 0) {
    bar.style.display = 'flex';
    if (countEl) countEl.textContent = '已选 ' + selectedRuleIds.size + ' 条';
  } else {
    bar.style.display = 'none';
  }
}

function batchEnable(enable) {
  let n = 0;
  state.rules.forEach(r => {
    if (selectedRuleIds.has(r.id)) { r.enabled = enable; n++; }
  });
  saveState();
  renderRules();
  toast('已' + (enable ? '启用' : '禁用') + ' ' + n + ' 条规则', 'success');
}

function batchDelete() {
  if (selectedRuleIds.size === 0) return;
  if (!confirm('确认删除选中的 ' + selectedRuleIds.size + ' 条规则？此操作不可恢复。')) return;
  state.rules = state.rules.filter(r => !selectedRuleIds.has(r.id));
  selectedRuleIds.clear();
  saveState();
  renderRules();
  toast('批量删除完成', 'success');
}

function batchDuplicate() {
  const toCopy = state.rules.filter(r => selectedRuleIds.has(r.id));
  if (toCopy.length === 0) return;
  toCopy.forEach(r => {
    state.rules.push(Object.assign({}, r, { id: genId() }));
  });
  selectedRuleIds.clear();
  saveState();
  renderRules();
  toast('已复制 ' + toCopy.length + ' 条规则（添加到列表末尾）', 'success');
}

// === 单条复制 ===
function duplicateRule(id) {
  const rule = state.rules.find(r => r.id === id);
  if (!rule) return;
  const idx = state.rules.indexOf(rule);
  const copy = Object.assign({}, rule, { id: genId() });
  state.rules.splice(idx + 1, 0, copy);
  saveState();
  renderRules();
  toast('已复制到原规则下方', 'success');
}

function addRule() {
  const defaultDomain = state.domains.find(d => d.isDefault) || state.domains[0];
  // 取当前地域筛选值作为新规则的默认地域
  const currentRegion = (document.getElementById('ruleRegionFilter') || {}).value || '';
  state.rules.push({
    id: genId(),
    type: 'keyword_contains',
    value: '',
    region: currentRegion,
    domainId: defaultDomain ? defaultDomain.id : '',
    path: '/yuanqu/list/',
    query: 'utm_source=SEM-baidu-PC&utm_medium=PC',
    remark: '',
    enabled: true
  });
  saveState();
  renderRules();
  toast('已添加规则（优先级最低）', 'success');
}

// 刷新地域筛选下拉
function refreshRegionFilter() {
  const sel = document.getElementById('ruleRegionFilter');
  if (!sel) return;
  const current = sel.value;
  // 收集所有非空地域
  const regions = [];
  const seen = new Set();
  state.rules.forEach(r => {
    if (r.region && r.region.trim() && !seen.has(r.region.trim())) {
      regions.push(r.region.trim());
      seen.add(r.region.trim());
    }
  });
  regions.sort();
  let opts = '<option value="">全部地域</option>';
  regions.forEach(r => {
    opts += '<option value="' + escapeHtml(r) + '"' + (r === current ? ' selected' : '') + '>' + escapeHtml(r) + '</option>';
  });
  sel.innerHTML = opts;
  // 如果当前选中的地域已被删除，恢复为全部
  if (current && !seen.has(current)) {
    sel.value = '';
  }
}

function deleteRule(id) {
  if (!confirm('确认删除这条规则？')) return;
  state.rules = state.rules.filter(r => r.id !== id);
  saveState();
  renderRules();
  toast('已删除', 'success');
}

function editRemark(id) {
  const rule = state.rules.find(r => r.id === id);
  if (!rule) return;
  const v = prompt('请输入备注（用于结果展示）：', rule.remark || '');
  if (v !== null) {
    rule.remark = v;
    saveState();
    renderRules();
  }
}

// === 批量粘贴建规则 ===
function toggleBatchPaste() {
  const card = document.getElementById('batchPasteCard');
  card.classList.toggle('hidden');
}

function updateBatchPasteHint() {
  const fmt = document.querySelector('input[name="batchFormat"]:checked').value;
  const hints = {
    puu: '三列 Tab 分隔：<b>计划名</b> <b>单元名</b> <b>完整URL</b>。匹配类型自动设为「计划+单元」，value格式：<code>计划|||单元</code>。<br>示例：<span class="mono">上海-大词&nbsp;&nbsp;园区&nbsp;&nbsp;https://sh.xuannaer.com.cn/yuanqu/list/?utm_source=SEM-baidu-PC</span>',
    uu: '两列 Tab 分隔：<b>单元名</b> <b>完整URL</b>。匹配类型自动设为「单元精确」。<br>示例：<span class="mono">园区-奉贤URL&nbsp;&nbsp;https://sh.xuannaer.com.cn/fengxian/yuanqu/list/?utm_source=SEM-baidu-PC</span>',
    custom: '自定义列格式：每行用 Tab 分隔，列顺序为 <b>匹配类型</b> <b>匹配值</b> <b>完整URL</b>。<br>匹配类型可选：keyword_exact, keyword_contains, keyword_regex, unit_exact, unit_contains, plan_exact, plan_contains, plan_unit_exact, category_exact, category_contains<br>示例：<span class="mono">unit_contains&nbsp;&nbsp;厂房&nbsp;&nbsp;https://sh.xuannaer.com.cn/changfang/?utm_source=SEM-baidu-PC</span>'
  };
  document.getElementById('batchPasteHint').innerHTML = hints[fmt];
  updateBatchPasteCount();
}

function updateBatchPasteCount() {
  const text = (document.getElementById('batchPasteArea') || {}).value || '';
  const lines = text.split(/\r?\n/).filter(l => l.trim());
  const el = document.getElementById('batchPasteCount');
  if (el) el.textContent = lines.length + ' 行';
}

function batchPasteCreate() {
  const text = document.getElementById('batchPasteArea').value;
  if (!text.trim()) { toast('请先粘贴内容', 'danger'); return; }
  const fmt = document.querySelector('input[name="batchFormat"]:checked').value;
  const lines = text.split(/\r?\n/).map(l => l.replace(/\r/g, '')).filter(l => l.trim());

  if (lines.length === 0) { toast('没有有效行', 'danger'); return; }
  if (state.domains.length === 0) { toast('请先到「域名管理」添加域名', 'danger'); return; }

  let added = 0, failed = 0;
  const defaultDomain = state.domains.find(d => d.isDefault) || state.domains[0];

  lines.forEach(line => {
    const parts = line.split('\t');
    let rule = null;

    if (fmt === 'puu') {
      // 计划 单元 URL
      if (parts.length >= 3) {
        const plan = parts[0].trim();
        const unit = parts[1].trim();
        const url = parts[2].trim();
        if (plan && unit && url) {
          const parsed = parseUrlToRule(url);
          rule = {
            id: genId(),
            type: 'plan_unit_exact',
            value: plan + '|||' + unit,
            domainId: parsed.domainId || defaultDomain.id,
            path: parsed.path,
            query: parsed.query,
            remark: '[批量] ' + plan + '/' + unit,
            enabled: true
          };
        }
      }
    } else if (fmt === 'uu') {
      // 单元 URL
      if (parts.length >= 2) {
        const unit = parts[0].trim();
        const url = parts[1].trim();
        if (unit && url) {
          const parsed = parseUrlToRule(url);
          rule = {
            id: genId(),
            type: 'unit_exact',
            value: unit,
            domainId: parsed.domainId || defaultDomain.id,
            path: parsed.path,
            query: parsed.query,
            remark: '[批量] ' + unit,
            enabled: true
          };
        }
      }
    } else if (fmt === 'custom') {
      // 类型 值 URL
      if (parts.length >= 3) {
        const type = parts[0].trim();
        const value = parts[1].trim();
        const url = parts[2].trim();
        const validTypes = ['keyword_exact','keyword_contains','keyword_regex','unit_exact','unit_contains','plan_exact','plan_contains','plan_unit_exact','category_exact','category_contains'];
        if (validTypes.includes(type) && value && url) {
          const parsed = parseUrlToRule(url);
          rule = {
            id: genId(),
            type: type,
            value: value,
            domainId: parsed.domainId || defaultDomain.id,
            path: parsed.path,
            query: parsed.query,
            remark: '[批量] ' + value,
            enabled: true
          };
        }
      }
    }

    if (rule) {
      state.rules.push(rule);
      added++;
    } else {
      failed++;
    }
  });

  saveState();
  renderRules();
  document.getElementById('batchPasteArea').value = '';
  updateBatchPasteCount();

  if (added > 0) {
    toast('已添加 ' + added + ' 条规则' + (failed > 0 ? '，' + failed + ' 行格式错误已跳过' : ''), 'success');
  } else {
    toast('全部 ' + failed + ' 行格式错误，请检查列数和 URL', 'danger');
  }
}

// 把完整 URL 拆成 domainId + path + query
function parseUrlToRule(url) {
  try {
    // 去掉首尾空格
    url = url.trim();
    let netloc = '', path = '', query = '';
    // 提取协议
    const m = url.match(/^https?:\/\/([^\/]+)(\/[^?]*)?(\?.*)?$/);
    if (m) {
      netloc = m[1];
      path = m[2] || '/';
      query = m[3] ? m[3].substring(1) : '';
    } else {
      // 不规范URL，整个当path
      path = url;
    }
    // 找匹配的域名
    const domain = state.domains.find(d => {
      try {
        const dm = d.url.match(/^https?:\/\/([^\/]+)/);
        return dm && dm[1] === netloc;
      } catch { return false; }
    });
    return {
      domainId: domain ? domain.id : '',
      path: path,
      query: query
    };
  } catch(e) {
    return { domainId: '', path: url, query: '' };
  }
}

// ============ 域名渲染 ============
function renderDomains() {
  const body = document.getElementById('domainsBody');
  document.getElementById('domains-count').textContent = state.domains.length;

  if (state.domains.length === 0) {
    body.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="icon">🌐</div>暂无域名，点击右上角「添加域名」</div></td></tr>';
    return;
  }

  body.innerHTML = state.domains.map(d => {
    return '<tr>' +
      '<td><input type="radio" name="defaultDomain" value="' + d.id + '"' + (d.isDefault ? ' checked' : '') + ' onchange="setDefaultDomain(\'' + d.id + '\')"></td>' +
      '<td><input type="text" data-field="url" data-id="' + d.id + '" value="' + escapeHtml(d.url) + '" placeholder="https://www.example.com"></td>' +
      '<td><input type="text" data-field="remark" data-id="' + d.id + '" value="' + escapeHtml(d.remark) + '" placeholder="域名备注"></td>' +
      '<td><label class="switch"><input type="checkbox" data-field="enabled" data-id="' + d.id + '"' + (d.enabled ? ' checked' : '') + '><span class="slider"></span></label></td>' +
      '<td><button class="btn btn-sm btn-icon btn-danger" onclick="deleteDomain(\'' + d.id + '\')">✕</button></td>' +
      '</tr>';
  }).join('');

  body.querySelectorAll('input').forEach(el => {
    const ev = el.type === 'checkbox' ? 'change' : 'input';
    el.addEventListener(ev, function() {
      if (this.type === 'radio') return;
      const id = this.dataset.id;
      const field = this.dataset.field;
      const d = state.domains.find(x => x.id === id);
      if (!d) return;
      d[field] = (this.type === 'checkbox') ? this.checked : this.value;
      saveState();
    });
  });
}

function addDomain() {
  state.domains.push({
    id: genId(),
    url: 'https://',
    remark: '',
    isDefault: state.domains.length === 0,
    enabled: true
  });
  saveState();
  renderDomains();
}

function deleteDomain(id) {
  const used = state.rules.filter(r => r.domainId === id).length;
  let msg = '确认删除这个域名？';
  if (used) msg += '\n警告：有 ' + used + ' 条规则在使用此域名，删除后这些规则将无法生成有效URL。';
  if (!confirm(msg)) return;
  state.domains = state.domains.filter(d => d.id !== id);
  saveState();
  renderDomains();
}

function setDefaultDomain(id) {
  state.domains.forEach(d => d.isDefault = (d.id === id));
  saveState();
}

// ============ 默认URL ============
function saveDefaultUrl() {
  state.defaultUrl = document.getElementById('defaultUrl').value;
  saveState();
}

function loadDefaultUrlUI() {
  document.getElementById('defaultUrl').value = state.defaultUrl || '';
}

// ============ 拖拽排序 ============
function enableDragSort(tbody, type) {
  let dragId = null;
  tbody.querySelectorAll('tr').forEach(tr => {
    tr.addEventListener('dragstart', function() {
      dragId = this.dataset.id;
      this.classList.add('dragging');
    });
    tr.addEventListener('dragend', function() {
      this.classList.remove('dragging');
      tbody.querySelectorAll('tr').forEach(t => t.classList.remove('drag-over'));
    });
    tr.addEventListener('dragover', function(e) {
      e.preventDefault();
      this.classList.add('drag-over');
    });
    tr.addEventListener('dragleave', function() {
      this.classList.remove('drag-over');
    });
    tr.addEventListener('drop', function(e) {
      e.preventDefault();
      this.classList.remove('drag-over');
      if (!dragId || dragId === this.dataset.id) return;
      const fromIdx = state.rules.findIndex(r => r.id === dragId);
      const toIdx = state.rules.findIndex(r => r.id === this.dataset.id);
      if (fromIdx < 0 || toIdx < 0) return;
      const [moved] = state.rules.splice(fromIdx, 1);
      state.rules.splice(toIdx, 0, moved);
      saveState();
      renderRules();
      toast('优先级已调整', 'success');
    });
  });
}

// ============ 导入导出 ============
function exportConfig() {
  const data = JSON.stringify(state, null, 2);
  const blob = new Blob([data], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = '百度竞价URL匹配规则_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  toast('规则已导出', 'success');
}

function importConfig(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data = JSON.parse(e.target.result);
      if (!data.domains || !data.rules) throw new Error('配置格式不正确');
      if (!confirm('导入将覆盖当前所有规则和域名，是否继续？\n\n导入后记得点「保存到文件」把数据写回HTML。')) return;
      state = Object.assign(state, data);
      saveState();
      renderRules();
      renderDomains();
      loadDefaultUrlUI();
      toast('规则导入成功（记得点「保存到文件」）', 'success');
    } catch(err) {
      toast('导入失败：' + err.message, 'danger');
    }
  };
  reader.readAsText(file);
  event.target.value = '';
}

function clearAllData() {
  if (!confirm('确认清空所有规则、域名和默认URL？此操作不可恢复！\n\n建议先「导出规则」或「保存到文件」备份。')) return;
  if (!confirm('再次确认：真的要清空全部数据吗？')) return;
  state = { domains: [], rules: [], defaultUrl: '', lastResults: [] };
  localStorage.removeItem(STORAGE_KEY);
  // 同步清空内嵌数据区
  const el = document.getElementById('embedded-data');
  if (el) el.textContent = '/*EMBEDDED_DATA_PLACEHOLDER*/';
  renderRules();
  renderDomains();
  loadDefaultUrlUI();
  clearResults();
  unsavedChanges = true;
  updateSaveButtonHint();
  toast('已清空全部数据（记得点「保存到文件」生效到HTML）', 'success');
}

// ============ 输入提示 ============
function updateInputHint() {
  const fmt = document.querySelector('input[name="inputFormat"]:checked').value;
  const hints = {
    keyword: '每行一个关键词。示例：<br><span class="mono">奉贤区产业园厂房租赁</span><br><span class="mono">卢湾工业园厂房</span>',
    pu: '三列 Tab 分隔（计划 / 单元 / 关键词），可直接从 Excel 复制 3 列。示例：<br><span class="mono">上海-大词\t园区\t奉贤区产业园厂房租赁</span><br><span class="mono">写字楼-上海\t行政区划-黄浦-huangpu\t上海黄浦区写字楼出租</span>',
    full: '四列 Tab 分隔（计划 / 单元 / 关键词 / 业务类别）。示例：<br><span class="mono">上海-大词\t园区\t奉贤区产业园厂房租赁\t园区</span><br><span class="mono">仓库-天津-纯\t武清区\t天津武清仓库出租\t仓库</span>'
  };
  document.getElementById('inputHint').innerHTML = hints[fmt];
}

// ============ 初始化 ============
loadState();
loadDefaultUrlUI();
updateInputHint();
updateBatchPasteHint();
// 绑定批量粘贴输入框行数统计
document.addEventListener('DOMContentLoaded', function() {
  const ta = document.getElementById('batchPasteArea');
  if (ta) ta.addEventListener('input', updateBatchPasteCount);
});
renderRules();
renderDomains();
updateSaveButtonHint();

// 快捷键：Ctrl+S 保存到文件
document.addEventListener('keydown', function(e) {
  if ((e.ctrlKey || e.metaKey) && e.key === 's') {
    e.preventDefault();
    saveToHtmlFile();
  }
});
</script>


</body></html>